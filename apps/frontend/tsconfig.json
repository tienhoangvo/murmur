{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "paths": {
      "@murmur/shared": ["../../packages/shared/src"],
      "@murmur/shared/*": ["../../packages/shared/src/*"],
      "@/*": ["./src/*"]
    },
    "noEmit": true
  },
  "include": ["src"]
}
